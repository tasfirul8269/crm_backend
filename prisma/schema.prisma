generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String              @id @default(cuid())
  fullName                   String
  username                   String              @unique
  email                      String              @unique
  password                   String
  avatarUrl                  String?
  role                       Role
  permissions                String[]
  otp                        String?
  otpExpiresAt               DateTime?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  isActive                   Boolean             @default(true)
  refreshToken               String?
  notificationSoundEnd       Float?
  notificationSoundStart     Float?              @default(0)
  notificationSoundUrl       String?
  sidebarMenuOrder           String[]
  useCustomNotificationSound Boolean             @default(false)
  isNotificationMuted        Boolean             @default(false)
  activityLogs               ActivityLog[]
  notificationSounds         NotificationSound[]
  otpDeviceLocks             OtpDeviceLock[]
  offPlanProperties          OffPlanProperty[]
}

model OtpDeviceLock {
  id          String    @id @default(cuid())
  deviceId    String
  userId      String
  attempts    Int       @default(0)
  lockedUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])

  @@unique([userId, deviceId])
}

model Developer {
  id                   String            @id @default(cuid())
  name                 String
  email                String            @unique
  phone                String
  logoUrl              String?
  about                String?
  salesManagerName     String
  salesManagerEmail    String
  salesManagerPhone    String
  salesManagerPhotoUrl String?
  nationality          String?
  languages            String[]
  isActive             Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  properties           OffPlanProperty[]
}

model OffPlanProperty {
  id                   String    @id @default(cuid())
  developerId          String
  emirate              String?
  launchType           String?
  projectHighlight     String?
  plotArea             Float?
  area                 Float?
  bedrooms             String?
  kitchens             Int?
  bathrooms            Int?
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  address              String?
  focalPoint           String?
  focalPointImage      String?
  latitude             Float?
  longitude            Float?
  nearbyHighlights     Json?
  style                String?
  propertyType         String[]
  agentVideoUrl        String?
  amenities            Json?
  amenitiesCover       String?
  amenitiesSubtitle    String?
  amenitiesTitle       String?
  brochure             String?
  brokerFee            String?
  constructionProgress Float?
  coverPhoto           String?
  dldPermitNumber      String?
  dldQrCode            String?
  exteriorMedia        String[]
  floorPlans           Json?
  handoverDate         DateTime?
  interiorMedia        String[]
  paymentPlan          Json?
  projectDescription   String?
  projectStage         String?
  projectTitle         String?
  reference            String?
  roiPotential         Float?
  serviceCharges       Float?
  shortDescription     String?
  startingPrice        Float?
  videoUrl             String?
  virtualTourUrl       String?
  areaExperts          Json?
  projectExperts       String[]
  approvalStatus       String    @default("APPROVED")
  createdByAdminId     String?
  createdByAgentId     String?
  createdByAdmin       User?     @relation(fields: [createdByAdminId], references: [id])
  createdByAgent       Agent?    @relation(fields: [createdByAgentId], references: [id])
  developer            Developer @relation(fields: [developerId], references: [id])

  @@index([developerId])
  @@index([startingPrice])
  @@index([createdAt])
  @@index([isActive])
}

model Agent {
  id                   String          @id @default(cuid())
  name                 String
  username             String          @unique
  email                String          @unique
  password             String
  photoUrl             String?
  coverPhotoUrl        String?
  position             String
  department           String
  phone                String
  whatsapp             String?
  address              String?
  vcardUrl             String?
  nationality          String?
  languages            String[]
  about                String?
  birthdate            DateTime?
  joinedDate           DateTime?
  visaExpiryDate       DateTime?
  areasExpertIn        String[]
  isActive             Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  pfPublicProfileId    String?
  pfUserId             String?
  experienceSince      Int?
  linkedinAddress      String?
  phoneSecondary       String?
  compliances          Json?
  licenseDocumentUrl   String?
  pfVerificationStatus String?
  agentPasswords       AgentPassword[]
  leadsResponsibleFor  Lead[]
  properties           Property[]
  offPlanProperties    OffPlanProperty[]
}

model AgentPassword {
  id        String   @id @default(cuid())
  agentId   String
  email     String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Amenity {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Property {
  id                   String            @id @default(cuid())
  category             String
  purpose              String
  clientName           String
  nationality          String?
  phoneNumber          String
  emirate              String?
  propertyType         String?
  plotArea             Float?
  area                 Float?
  bedrooms             String?
  kitchens             Int?
  bathrooms            Int?
  unitNumber           String?
  ownershipStatus      String?
  parkingSpaces        String?
  address              String?
  latitude             Float?
  longitude            Float?
  furnishingType       String?
  price                Float?
  rentalPeriod         String?
  brokerFee            String?
  numberOfCheques      String?
  dldPermitNumber      String?
  dldQrCode            String?
  propertyTitle        String?
  propertyDescription  String?
  coverPhoto           String?
  videoUrl             String?
  mediaImages          String[]
  reference            String?
  availableFrom        DateTime?
  amenities            String[]
  nocDocument          String?
  assignedAgentId      String?
  isActive             Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  emiratesIdScan       String?
  passportCopy         String?
  titleDeed            String?
  phoneCountry         String?           @default("AE")
  status               PropertyStatus    @default(AVAILABLE)
  hasKitchen           Boolean?
  pfListingId          String?
  pfPublished          Boolean           @default(false)
  pfQualityScore       Float?
  pfSyncedAt           DateTime?
  pfVerificationStatus String?
  pfLocationId         Int?
  pfLocationPath       String?
  completionDate       String?
  projectStatus        String?
  approvalStatus       String            @default("APPROVED")
  assignedAgent        Agent?            @relation(fields: [assignedAgentId], references: [id])
  tenancyContracts     TenancyContract[]

  @@index([isActive, pfPublished])
  @@index([isActive, status])
  @@index([price])
  @@index([createdAt])
  @@index([category])
  @@index([purpose])
  @@index([bedrooms])
  @@index([area])
  @@index([isActive, pfPublished, purpose])
}

model PropertyDraft {
  id                 String   @id @default(cuid())
  data               Json
  originalPropertyId String?
  userId             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Lead {
  id                 String    @id @default(cuid())
  name               String
  email              String
  phone              String
  organizer          String?
  responsible        String?
  observers          String[]
  status             String?
  dealPrice          Float?
  currency           String?   @default("AED")
  source             String?
  closingDate        DateTime?
  district           String?
  propertyType       String?
  developer          String?
  bedrooms           String?
  budgetFrom         Float?
  budgetTo           Float?
  areaFrom           String?
  areaTo             String?
  additionalContent  String?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  responsibleAgentId String?
  responsibleAgent   Agent?    @relation(fields: [responsibleAgentId], references: [id])
}

model PropertyFinderLead {
  id                   String   @id @default(cuid())
  pfId                 String   @unique
  name                 String
  email                String
  phone                String
  channel              String
  status               String
  comments             String?
  listingId            String?
  listingReference     String?
  assignedToIdentifier String?
  dealPrice            Float?
  createdAt            DateTime
  fetchedAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model IntegrationConfig {
  id          String   @id @default(cuid())
  provider    String   @unique
  isEnabled   Boolean  @default(false)
  credentials Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  ipAddress String?
  location  String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PfLocation {
  id        Int      @id
  name      String
  path      String
  type      String?
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Noc {
  id                  String     @id @default(cuid())
  propertyType        String?
  buildingProjectName String?
  community           String?
  streetName          String?
  buildUpArea         Float?
  plotArea            Float?
  bedrooms            String?
  bathrooms           Int?
  rentalAmount        Float?
  saleAmount          Float?
  parking             String?
  agreementType       String?
  periodMonths        Int?
  agreementDate       DateTime?
  pdfUrl              String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  clientPhone         String?
  latitude            Float?
  location            String?
  longitude           Float?
  propertyNumber      String?
  owners              NocOwner[]
}

model AiSettings {
  id                 String   @id @default(cuid())
  minCharacters      Int      @default(750)
  maxCharacters      Int      @default(2000)
  isEnabled          Boolean  @default(true)
  modelName          String   @default("gemini-2.5-flash")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  maxTitleCharacters Int      @default(100)
  minTitleCharacters Int      @default(30)
}

model AiTrainingExample {
  id          String   @id @default(cuid())
  title       String?
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  type        String   @default("description")
}

model NocOwner {
  id            String    @id @default(cuid())
  nocId         String
  name          String?
  emiratesId    String?
  issueDate     DateTime?
  expiryDate    DateTime?
  countryCode   String?
  phone         String?
  signatureUrl  String?
  signatureDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  noc           Noc       @relation(fields: [nocId], references: [id], onDelete: Cascade)
}

model Folder {
  id        String    @id @default(cuid())
  name      String
  parentId  String?
  isSystem  Boolean   @default(false)
  size      Int       @default(0)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  color     String?
  files     File[]
  parent    Folder?   @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]  @relation("FolderToFolder")
}

model File {
  id        String    @id @default(cuid())
  name      String
  url       String
  mimeType  String
  size      Int       @default(0)
  folderId  String?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  folder    Folder?   @relation(fields: [folderId], references: [id], onDelete: Cascade)
}

model PasswordEntry {
  id        String   @id @default(cuid())
  title     String
  username  String
  password  String
  accessIds String[]
  note      String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logoUrl   String?
}

model TenancyContract {
  id                String    @id @default(cuid())
  propertyId        String?
  ownerName         String?
  ownerPhone        String?
  ownerEmail        String?
  tenantName        String?
  tenantEmail       String?
  tenantPhone       String?
  propertyUsage     String?
  buildingName      String?
  location          String?
  propertySize      Float?
  propertyType      String?
  propertyNumber    String?
  plotNumber        String?
  premisesNumber    String?
  contractStartDate DateTime?
  contractEndDate   DateTime?
  annualRent        Float?
  contractValue     Float?
  securityDeposit   Float?
  modeOfPayment     String?
  additionalTerms   Json?
  pdfUrl            String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  property          Property? @relation(fields: [propertyId], references: [id])
}

model Watermark {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String?
  position  String   @default("bottom-right")
  opacity   Float    @default(0.8)
  scale     Float    @default(0.15)
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blendMode String   @default("Normal")
  rotation  Float    @default(0)
  text      String?
  textColor String?  @default("#FFFFFF")
  type      String   @default("image")
}

model NotificationSound {
  id        String   @id @default(cuid())
  userId    String
  name      String
  url       String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PropertyClientDetails {
  id              String   @id @default(cuid())
  propertyId      String   @unique
  clientName      String?
  nationality     String?
  phoneCountry    String?
  phoneNumber     String?
  nocDocument     String?
  passportCopy    String?
  emiratesIdScan  String?
  titleDeed       String?
  ownershipStatus String?
  brokerFee       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  address         String?
  latitude        Float?
  longitude       Float?
}

model Task {
  id          String   @id @default(cuid())
  title       String
  note        String?
  date        DateTime
  startTime   String?
  endTime     String?
  category    String?
  isCompleted Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([createdBy])
}

enum Role {
  ADMIN
  MODERATOR
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
}
